# claude-code-notify configuration
# Copy to ~/.config/claude-notify/config and edit to match your setup.

# Notification backend: dunst | mako | generic
# dunst:   clickable actions via context menu (or mouse_left_click = do_action)
# mako:    inline clickable action buttons (requires libnotify 0.8+ for --wait)
# generic: basic notify-send, no actions — relies on WM keybindings
CN_NOTIFY_BACKEND=dunst

# Window manager: niri | sway | hyprland | none
# Used for focus detection (skip notifications when terminal is visible)
# and for "go to" functionality (focus terminal window)
# none: always send notifications, "go to" only switches tmux pane
CN_WM_BACKEND=niri

# Terminal app ID for WM focus detection and "go to"
# Common values: com.mitchellh.ghostty, Alacritty, kitty, foot, org.wezfurlong.wezterm
CN_TERMINAL_APP_ID=com.mitchellh.ghostty

# Input method for direct (non-tmux) terminal response
# wtype: Wayland (default), xdotool: X11
CN_INPUT_METHOD=wtype

# Keybinding labels shown in notifications.
# Only rendered when the active backend can NOT show inline action buttons
# (i.e., CN_NOTIFY_BACKEND=generic). On dunst the notification exposes
# clickable buttons instead, so these values are unused.
CN_KEY_ALLOW="Ctrl+Super+Y"
CN_KEY_ALWAYS_ALLOW="Ctrl+Super+A"
CN_KEY_DENY="Ctrl+Super+N"
CN_KEY_NEXT="Ctrl+Super+P"
CN_KEY_GOTO="Ctrl+Super+O"
